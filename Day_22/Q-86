#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cout << "Enter a sentence: ";
    getline(cin, s);

    int count = 0;

    for (int i = 0; i < s.length(); i++) {
        if (s[i] == ' ')
            count++;
    }

    cout << "Number of words: " << count + 1 << endl;

    return 0;
}
