#include <iostream>
using namespace std;
int main()
{ 
    int num, digit, sum=0;
    cout << "Enter a Number: ";
    cin >> num;
    cout << "Sum of Digits " << num << " is : ";
    while(num !=0)
    {
      digit = num % 10;
      sum = sum + digit;
      num = num/10;
    }
    cout << sum;
    return 0;   
}
