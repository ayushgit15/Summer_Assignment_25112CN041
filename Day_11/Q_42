#include <iostream>
using namespace std;

int main()
{
    int size;
    cout << "Enter the number of elements: ";
    cin >> size;

    int arr[size];
    cout << "Enter " << size << " numbers: ";
    for (int i = 0; i < size; i++)
    {
        cin >> arr[i];
    }

    cout << "The maximum number is: " << max(arr, size) << endl;
    return 0;
}
