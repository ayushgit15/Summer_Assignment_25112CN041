#include <iostream>
using namespace std;
int main()
{ 
    int num;
    cout << "Enter a Number: ";
    cin >> num;
    cout << "Multiplication Table  of " << num << " is displayed below :\n";
    
    for(int i=1; i <= 10; i++){
    cout << num << " x " << i << " = " << num*i << "\n";
    }

    return 0;
}
