#include <iostream>
using namespace std;
int main()
{ 
    int n, sum=0;
    cout <<"Enter the Number upto which you want to calculate the sum: ";
    cin >> n;
    for (int i = 1; i<=n; i++)
    {
        sum += i;
    }
    cout << "Sum of first "<< n << " natural numbers = "<< sum << endl;

    return 0;
}
